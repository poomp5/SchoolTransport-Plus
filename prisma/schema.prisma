datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
